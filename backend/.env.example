# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored; never commit real secrets.
#
# Format:
#   postgresql://USERNAME:PASSWORD@HOST:5432/DBNAME?sslmode=require
#
# For Azure Database for PostgreSQL Flexible Server, sslmode=require is mandatory.

DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Azure OpenAI — required for the /api/chat endpoint.
# Endpoint: base URL of your Azure OpenAI resource (no path, no query string).
#   e.g. https://YOUR-RESOURCE.openai.azure.com
# Deployment: the deployment Name from Azure AI Foundry (not the model name).
# Extractor deployment: optional; falls back to AZURE_OPENAI_DEPLOYMENT.
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_KEY
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_EXTRACTOR_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-10-21
