# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored; never commit real secrets.
#
# Format:
#   postgresql://USERNAME:PASSWORD@HOST:5432/DBNAME?sslmode=require
#
# For Azure Database for PostgreSQL Flexible Server, sslmode=require is mandatory.

DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Azure OpenAI — required for the /api/chat endpoint.
# Endpoint: from your Azure OpenAI resource overview (no trailing slash).
# Deployment: the Name (not the model name) shown under Model deployments.
AZURE_OPENAI_ENDPOINT=https://azure-openaitest-01.openai.azure.com/openai/deployments/gpt-4.1/chat/completions?api-version=2025-01-01-preview
AZURE_OPENAI_API_KEY=6c66ef21522c4d91ad262ef41a178a15
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-10-21

